# ============================================================
# Snakefile — Pipeline RNA-seq cacao x Moniliophthora roreri
# Sección 2.4 — Expresión diferencial propia
# Autor: Jossimar Vicente
# ============================================================

MUESTRAS = ["SRR1034656"]

RAW     = "data/raw/meinhardt2014"
GENOME  = "data/genome"
PROC    = "data/processed"
LOGS    = "logs"

GENOME_FA  = GENOME + "/Tcacao_523_v2.0.fa"
GENOME_IDX = GENOME + "/Tcacao_523_v2.0_index"
GENOME_GFF = GENOME + "/Tcacao_523_v2.1.gene.gff3"

# ============================================================
# Regla final: archivos que queremos al terminar todo
# ============================================================
rule all:
    input:
        expand(PROC + "/fastp/{muestra}_1_clean.fastq.gz", muestra=MUESTRAS),
        expand(PROC + "/fastp/{muestra}_2_clean.fastq.gz", muestra=MUESTRAS),
        expand(PROC + "/fastp/{muestra}_report.html",      muestra=MUESTRAS),
        expand(PROC + "/hisat2/{muestra}.bam",             muestra=MUESTRAS),
        expand(PROC + "/hisat2/{muestra}.bam.bai",         muestra=MUESTRAS),
        expand(PROC + "/counts/{muestra}_counts.txt",      muestra=MUESTRAS)

# ============================================================
# Regla 1: convertir SRA a FASTQ
# ============================================================
rule sra_a_fastq:
    input:
        RAW + "/{muestra}/{muestra}.sra"
    output:
        r1 = PROC + "/fastq/{muestra}_1.fastq.gz",
        r2 = PROC + "/fastq/{muestra}_2.fastq.gz"
    log:
        LOGS + "/fastq-dump/{muestra}.log"
    threads: 4
    shell:
        """
        mkdir -p {PROC}/fastq
        fasterq-dump {input} \
            --outdir {PROC}/fastq \
            --threads {threads} \
            --split-files \
            --progress \
            2> {log}
        gzip {PROC}/fastq/{wildcards.muestra}_1.fastq
        gzip {PROC}/fastq/{wildcards.muestra}_2.fastq
        """

# ============================================================
# Regla 2: limpiar lecturas con fastp
# ============================================================
rule fastp_limpiar:
    input:
        r1 = PROC + "/fastq/{muestra}_1.fastq.gz",
        r2 = PROC + "/fastq/{muestra}_2.fastq.gz"
    output:
        r1   = PROC + "/fastp/{muestra}_1_clean.fastq.gz",
        r2   = PROC + "/fastp/{muestra}_2_clean.fastq.gz",
        html = PROC + "/fastp/{muestra}_report.html",
        json = PROC + "/fastp/{muestra}_report.json"
    log:
        LOGS + "/fastp/{muestra}.log"
    threads: 4
    shell:
        """
        mkdir -p {PROC}/fastp
        fastp \
            --in1 {input.r1} \
            --in2 {input.r2} \
            --out1 {output.r1} \
            --out2 {output.r2} \
            --html {output.html} \
            --json {output.json} \
            --thread {threads} \
            --detect_adapter_for_pe \
            2> {log}
        """

# ============================================================
# Regla 3: alinear lecturas al genoma con HISAT2
# BAM = formato binario comprimido de alineamiento
# ============================================================
rule hisat2_alinear:
    input:
        r1  = PROC + "/fastp/{muestra}_1_clean.fastq.gz",
        r2  = PROC + "/fastp/{muestra}_2_clean.fastq.gz",
        idx = GENOME_IDX + ".1.ht2"
    output:
        bam = PROC + "/hisat2/{muestra}.bam",
        bai = PROC + "/hisat2/{muestra}.bam.bai"
    log:
        LOGS + "/hisat2/{muestra}.log"
    threads: 4
    shell:
        """
        mkdir -p {PROC}/hisat2
        hisat2 \
            -x {GENOME_IDX} \
            -1 {input.r1} \
            -2 {input.r2} \
            --threads {threads} \
            --dta \
            2> {log} | \
        samtools sort -@ {threads} -o {output.bam}
        samtools index {output.bam}
        """

# ============================================================
# Regla 4: contar lecturas por gen con featureCounts
# Produce tabla gen -> número de lecturas
# featureCounts es más rápido que htseq-count
# ============================================================
rule contar_lecturas:
    input:
        bam = PROC + "/hisat2/{muestra}.bam",
        gff = GENOME_GFF
    output:
        PROC + "/counts/{muestra}_counts.txt"
    log:
        LOGS + "/featureCounts/{muestra}.log"
    threads: 4
    shell:
        """
        mkdir -p {PROC}/counts
        featureCounts \
            -T {threads} \
            -p \
            -t gene \
            -g Name \
            -a {input.gff} \
            -o {output} \
            {input.bam} \
            2> {log}
        """
